---
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  title: string;
  description: string;
  version: string;
}

const { lang, title, description, version } = Astro.props;
---
<button type="button" class="plugin-card" data-topaz-open aria-expanded="false">
  <div class="card-inner">
    <span class="version">{version}</span>

    <div class="plugin-copy">
      <h2 class="plugin-title">
        <span data-i18n="project.title">{title}</span>
        <span class="plugin-title-emoji" aria-hidden="true">🍞</span>
      </h2>

      <p class="description" data-i18n="project.subtitle">{description}</p>
    </div>

    <span class="corner-arrow" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none">
        <path d="M5 15L15 5" />
        <path d="M8 5H15V12" />
      </svg>
    </span>
  </div>
</button>

<style>
  .plugin-card {
    width: 100%;
    display: block;
    text-align: left;
    background: linear-gradient(180deg, #76aec3, #74abc0);
    border-radius: 26px;
    color: #ffffff;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
    box-shadow: 0 14px 28px rgba(121, 180, 201, 0.14);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    position: relative;
  }

  .plugin-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 30px rgba(121, 180, 201, 0.18);
  }

  .plugin-card:hover .corner-arrow {
    transform: translate(2px, -2px);
    opacity: 1;
  }

  .plugin-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
    pointer-events: none;
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 24px 26px 22px;
    min-height: 220px;
    position: relative;
    z-index: 1;
  }

  .plugin-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    width: min(100%, 520px);
  }

  .plugin-title {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    font-size: clamp(2rem, 4.1vw, 3.3rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    margin: 0;
    line-height: 0.94;
    flex-wrap: wrap;
    width: fit-content;
    max-width: 100%;
  }

  .plugin-title-emoji {
    font-size: 0.6em;
    line-height: 1;
    transform: translateY(-0.02em);
    filter: saturate(0.88);
  }

  .version {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .description {
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.92;
    margin: 0;
    max-width: 24ch;
  }

  .corner-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    position: absolute;
    right: 24px;
    bottom: 24px;
    opacity: 0.72;
    transition: transform 0.22s ease, opacity 0.22s ease;
  }

  .corner-arrow svg {
    width: 100%;
    height: 100%;
  }

  .corner-arrow path {
    stroke: rgba(255, 255, 255, 0.88);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 640px) {
    .plugin-card {
      border-radius: 22px;
    }

    .card-inner {
      padding: 18px;
      min-height: 0;
    }

    .description {
      max-width: none;
    }

    .corner-arrow {
      right: 18px;
      bottom: 18px;
      width: 18px;
      height: 18px;
    }
  }
</style>
