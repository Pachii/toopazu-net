---
interface Props {
  videos: { id: string, titles: Record<string, string> }[];
  titleI18nKey: string;
  titleText: string;
  defaultLang: string;
}
const { videos, titleI18nKey, titleText, defaultLang } = Astro.props;
---
{videos.length > 0 && (
  <div class="carousel-section">
    <div class="carousel-shell">
      <div class="carousel-header">
        <h3 class="section-title"><span data-i18n={titleI18nKey}>{titleText}</span></h3>
      </div>

      <div class="carousel-container" id="works-carousel">
        {videos.map((v, index) => (
          <a href={`https://youtube.com/watch?v=${v.id}`} target="_blank" rel="noopener noreferrer" class="carousel-item">
            <span class="item-index">{String(videos.length - index).padStart(2, '0')}</span>
            <div class="image-wrapper">
              <img src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`} alt="Cover" loading="lazy" />
            </div>
            <div class="item-footer">
              <p class="item-title" data-i18n={`video-${v.id}`}>{v.titles[defaultLang]}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="carousel-progress" aria-hidden="true">
        {videos.map((_, index) => (
          <button
            type="button"
            class={`progress-dot ${index === 0 ? 'is-active' : ''}`}
            data-index={index}
            aria-label={`Go to cover ${index + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
)}

<style>
  .carousel-section {
    margin-top: 32px;
    animation: fadeIn 0.6s ease forwards;
  }

  .carousel-shell {
    position: relative;
    padding: 18px;
    border-radius: calc(var(--border-radius) + 8px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.62)),
      linear-gradient(135deg, rgba(121, 180, 201, 0.12), rgba(255, 255, 255, 0));
    border: 1px solid rgba(121, 180, 201, 0.14);
    box-shadow: 0 16px 40px rgba(121, 180, 201, 0.08);
    overflow: hidden;
  }

  .carousel-header {
    margin-bottom: 18px;
  }

  .section-title {
    font-size: 0.98rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-main);
  }

  .carousel-container {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 18px;
    padding: 14px 4px 10px;
    -ms-overflow-style: none;
    scrollbar-width: none;
    overscroll-behavior-x: contain;
    mask-image: linear-gradient(to right, transparent 0, black 20px, black calc(100% - 20px), transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 20px, black calc(100% - 20px), transparent 100%);
  }

  .carousel-container::-webkit-scrollbar {
    display: none;
  }

  .carousel-item {
    flex: 0 0 min(72%, 360px);
    scroll-snap-align: center;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 14px 28px rgba(121, 180, 201, 0.14);
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.3s ease, background-color 0.3s ease;
    background: rgba(255, 255, 255, 0.88);
    display: flex;
    flex-direction: column;
    position: relative;
    text-decoration: none;
    border: 1px solid rgba(121, 180, 201, 0.12);
  }

  .carousel-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 34px rgba(121, 180, 201, 0.2);
  }

  .carousel-item.is-active {
    transform: translateY(-10px);
    box-shadow: 0 24px 40px rgba(121, 180, 201, 0.22);
  }

  .image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: #ebebeb;
    display: flex;
    position: relative;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .carousel-item:hover .image-wrapper img {
    transform: scale(1.04);
  }

  .item-index {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 34px;
    height: 26px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: #4f7f91;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
  }

  .item-footer {
    padding: 14px 16px 16px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.82)),
      rgba(255, 255, 255, 0.88);
  }

  .item-title {
    color: var(--text-main);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .carousel-progress {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 10px;
  }

  .progress-dot {
    width: 18px;
    height: 4px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(121, 180, 201, 0.18);
    transition: width 0.25s ease, background-color 0.25s ease, transform 0.25s ease;
    cursor: pointer;
  }

  .progress-dot.is-active {
    width: 34px;
    background: rgba(79, 127, 145, 0.72);
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .carousel-shell {
      padding: 14px;
    }

    .carousel-header {
      margin-bottom: 14px;
    }

    .carousel-container {
      gap: 14px;
      padding: 10px 2px 8px;
    }

    .carousel-item {
      flex-basis: 82%;
    }

    .carousel-item:hover {
      transform: translateY(-4px);
    }

    .carousel-item.is-active {
      transform: translateY(-6px);
    }

    .carousel-progress {
      gap: 6px;
      margin-top: 8px;
    }

    .progress-dot {
      width: 14px;
    }

    .progress-dot.is-active {
      width: 28px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('works-carousel');
    if (!carousel) return;
    const items = Array.from(carousel.querySelectorAll('.carousel-item'));
    const progressDots = Array.from(document.querySelectorAll('.progress-dot'));

    let isHovering = false;
    let frameId = 0;
    carousel.addEventListener('mouseenter', () => isHovering = true);
    carousel.addEventListener('mouseleave', () => isHovering = false);

    const updateActiveItem = () => {
      frameId = 0;

      const containerRect = carousel.getBoundingClientRect();
      const containerCenter = containerRect.left + containerRect.width / 2;
      let activeItem = null;
      let closestDistance = Number.POSITIVE_INFINITY;

      items.forEach((item) => {
        const rect = item.getBoundingClientRect();
        const itemCenter = rect.left + rect.width / 2;
        const distance = Math.abs(containerCenter - itemCenter);

        if (distance < closestDistance) {
          closestDistance = distance;
          activeItem = item;
        }
      });

      items.forEach((item) => {
        item.classList.toggle('is-active', item === activeItem);
      });

      const activeIndex = items.findIndex((item) => item === activeItem);
      progressDots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === activeIndex);
      });
    };

    const queueActiveUpdate = () => {
      if (frameId) return;
      frameId = window.requestAnimationFrame(updateActiveItem);
    };

    carousel.addEventListener('scroll', queueActiveUpdate, { passive: true });
    window.addEventListener('resize', queueActiveUpdate);
    progressDots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const target = items[index];
        if (!target) return;
        target.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
    });
    queueActiveUpdate();

    setInterval(() => {
      if (isHovering) return;

      const firstChild = carousel.firstElementChild as HTMLElement;
      if (!firstChild) return;

      const itemWidth = firstChild.offsetWidth + 18;
      const maxScroll = carousel.scrollWidth - carousel.clientWidth;

      if (carousel.scrollLeft >= maxScroll - 5) {
        carousel.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        carousel.scrollBy({ left: itemWidth, behavior: 'smooth' });
      }
    }, 4000);
  });
</script>
