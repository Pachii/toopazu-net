---
interface Props {
  tab1: string;
  tab2: string;
  tab3: string;
  initialTarget?: 'links-view' | 'projects-view' | 'commission-view';
}
const { tab1, tab2, tab3, initialTarget = 'links-view' } = Astro.props;
const initialIndex =
  initialTarget === 'projects-view' ? 1 : initialTarget === 'commission-view' ? 2 : 0;
---
<div class="tab-switcher-container">
  <div class={`tab-switcher pos-${initialIndex}`}>
    <button class={`tab-btn ${initialTarget === 'links-view' ? 'active' : ''}`} data-target="links-view">
      <span data-i18n="tab.main">{tab1}</span>
    </button>
    <button class={`tab-btn ${initialTarget === 'projects-view' ? 'active' : ''}`} data-target="projects-view">
      <span data-i18n="tab.special">{tab2}</span>
    </button>
    <button class={`tab-btn ${initialTarget === 'commission-view' ? 'active' : ''}`} data-target="commission-view">
      <span data-i18n="tab.commission">{tab3}</span>
    </button>
    <div class="tab-slider"></div>
  </div>
</div>

<style>
  .tab-switcher-container {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }

  .tab-switcher {
    position: relative;
    display: flex;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 24px;
    padding: 4px;
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
    width: 360px; /* Gives more room for English strings */
    max-width: 90vw;
  }

  .tab-btn {
    flex: 1; /* Both buttons always take up EXACTLY 33.333% */
    position: relative;
    z-index: 2;
    padding: 0;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1;
    color: var(--text-light);
    border-radius: 20px;
    transition: color 0.3s ease;
  }

  .tab-btn.active {
    color: var(--text-main);
  }

  .tab-slider {
    position: absolute;
    top: 4px;
    left: 4px;
    height: calc(100% - 8px);
    width: calc(33.333% - 2.66px); /* 1/3 minus padding adjustments */
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    z-index: 1;
  }

  /* Slider positions */
  .tab-switcher.pos-0 .tab-slider { transform: translateX(0); }
  .tab-switcher.pos-1 .tab-slider { transform: translateX(100%); }
  .tab-switcher.pos-2 .tab-slider { transform: translateX(200%); }
</style>

<script>
  import { buildAppPath, parseAppPath } from '../utils/appRoutes';

  function setupTabs() {
    const switcher = document.querySelector<HTMLElement>('.tab-switcher');
    const btns = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab-btn'));
    const views = {
      'links-view': document.getElementById('links-view'),
      'projects-view': document.getElementById('projects-view'),
      'commission-view': document.getElementById('commission-view'),
    } as const;

    if (!switcher || !btns.length) return;

    const notifyRouteChange = (target: string, pathname: string) => {
      document.dispatchEvent(
        new CustomEvent('app-route-change', {
          detail: { target, pathname },
        }),
      );
    };

    const setViewVisibility = (element: HTMLElement, visible: boolean, animate: boolean) => {
      if (visible) {
        element.style.display = 'block';

        if (!animate) {
          element.style.opacity = '1';
          element.style.transform = 'translateY(0)';
          return;
        }

        element.style.opacity = '0';
        element.style.transform = 'translateY(10px)';
        window.requestAnimationFrame(() => {
          element.style.opacity = '1';
          element.style.transform = 'translateY(0)';
        });
        return;
      }

      element.style.opacity = '0';
      element.style.transform = 'translateY(10px)';
      element.style.display = 'none';
    };

    const applyTabState = (target: string, animate: boolean) => {
      const nextIndex = btns.findIndex((btn) => btn.dataset.target === target);
      if (nextIndex === -1) return;

      switcher.classList.remove('pos-0', 'pos-1', 'pos-2');
      switcher.classList.add(`pos-${nextIndex}`);

      btns.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.target === target);
      });

      Object.entries(views).forEach(([viewId, element]) => {
        if (element instanceof HTMLElement) {
          setViewVisibility(element, viewId === target, animate);
        }
      });
    };

    const getTargetPath = (target: string) => {
      const { routeLang } = parseAppPath(window.location.pathname);

      if (target === 'projects-view') {
        return buildAppPath('projects-view', routeLang ?? '', 'software');
      }

      if (target === 'commission-view') {
        return buildAppPath('commission-view', routeLang ?? '');
      }

      return buildAppPath('links-view', routeLang ?? '');
    };

    const syncFromLocation = (animate: boolean) => {
      const { view } = parseAppPath(window.location.pathname);
      applyTabState(view, animate);
      notifyRouteChange(view, window.location.pathname);
    };

    btns.forEach((btn) => {
      btn.addEventListener('click', (event) => {
        const target = (event.currentTarget as HTMLButtonElement).dataset.target || 'links-view';
        const nextPath = getTargetPath(target);

        applyTabState(target, true);

        if (window.location.pathname !== nextPath) {
          window.history.pushState({ target }, '', nextPath);
        }

        notifyRouteChange(target, nextPath);
      });
    });

    window.addEventListener('popstate', () => {
      syncFromLocation(true);
    });

    const { view } = parseAppPath(window.location.pathname);
    applyTabState(view, false);
  }

  setupTabs();
</script>
