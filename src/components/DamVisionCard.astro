---
import { ui } from '../i18n/ui';
import { damVisionAssets } from '../data/damVision';
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  title: string;
  description: string;
  version: string;
}

const { lang, title, description, version } = Astro.props;
const t = (key: keyof typeof ui['en']) => ui[lang][key];
---
<button type="button" class="dam-card" data-project-open aria-expanded="false">
  <div class="dam-card-inner">
    <span class="dam-version" data-i18n="dam.version">{version}</span>

    <div class="dam-copy">
      <h2 class="dam-title" data-i18n="dam.title">{title}</h2>
      <p class="dam-description" data-i18n="dam.subtitle">{description}</p>

      <div class="dam-badges">
        <span class="dam-badge" data-i18n="dam.meta.type">{t('dam.meta.type')}</span>
        <span class="dam-badge" data-i18n="dam.meta.platforms">{t('dam.meta.platforms')}</span>
      </div>
    </div>

    <div class="dam-visual" aria-hidden="true">
      <img src={damVisionAssets.cardVisual} alt="" loading="lazy" />
    </div>

    <span class="dam-corner-arrow" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none">
        <path d="M5 15L15 5" />
        <path d="M8 5H15V12" />
      </svg>
    </span>
  </div>
</button>

<style>
  .dam-card {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    display: block;
    text-align: left;
    padding: 0;
    font: inherit;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0) 36%),
      linear-gradient(145deg, #7896b8 0%, #607ea3 56%, #4d6789 100%);
    border-radius: 26px;
    color: #fff;
    transition:
      transform 0.26s var(--project-card-hover-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      box-shadow 0.26s var(--project-card-hover-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      border-color 0.26s ease;
    box-shadow: 0 14px 28px rgba(58, 86, 118, 0.15);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    position: relative;
    transform-origin: center center;
    will-change: transform, box-shadow;
  }

  .dam-card:hover {
    transform: var(--project-card-hover-transform, translateY(-2px) scale(1.008));
    box-shadow: 0 20px 34px rgba(58, 86, 118, 0.21);
    border-color: rgba(255, 255, 255, 0.16);
  }

  .dam-card:hover .dam-corner-arrow {
    transform: translate(2px, -2px);
    opacity: 1;
  }

  .dam-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.01) 72%, rgba(255, 255, 255, 0));
    pointer-events: none;
  }

  .dam-card-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 24px 26px 22px;
    min-height: 220px;
    position: relative;
    z-index: 1;
  }

  .dam-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    width: min(100%, 420px);
    position: relative;
    z-index: 2;
  }

  .dam-title {
    margin: 0;
    font-size: clamp(2rem, 4.1vw, 3.15rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.96;
    color: #fff;
  }

  .dam-version {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    width: fit-content;
    position: relative;
    z-index: 2;
  }

  .dam-description {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.92;
    max-width: 34ch;
  }

  .dam-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 2px;
  }

  .dam-badge {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }

  .dam-corner-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    position: absolute;
    right: 24px;
    bottom: 24px;
    opacity: 0.72;
    transition:
      transform 0.26s var(--project-card-hover-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      opacity 0.26s ease;
  }

  .dam-corner-arrow svg {
    width: 100%;
    height: 100%;
  }

  .dam-corner-arrow path {
    stroke: rgba(255, 255, 255, 0.88);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .dam-visual {
    position: absolute;
    inset: 18px 20px 18px auto;
    width: min(42%, 430px);
    z-index: 1;
    overflow: hidden;
    border-radius: 24px;
    mask-image: linear-gradient(to right, transparent 0%, rgba(0, 0, 0, 0.84) 18%, rgba(0, 0, 0, 0.96) 52%, rgba(0, 0, 0, 0.94) 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0, 0, 0, 0.84) 18%, rgba(0, 0, 0, 0.96) 52%, rgba(0, 0, 0, 0.94) 100%);
    opacity: 0.9;
  }

  .dam-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to left, rgba(71, 99, 131, 0.02), rgba(71, 99, 131, 0.13)),
      radial-gradient(circle at center, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0) 62%);
    pointer-events: none;
  }

  .dam-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  @media (max-width: 640px) {
    .dam-card {
      border-radius: 22px;
    }

    .dam-card-inner {
      padding: 18px;
      min-height: 0;
    }

    .dam-description {
      max-width: none;
    }

    .dam-corner-arrow {
      right: 18px;
      bottom: 18px;
      width: 18px;
      height: 18px;
    }

    .dam-visual {
      display: none;
    }
  }
</style>
