---
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  title: string;
  description: string;
  version: string;
}

const { lang, title, description, version } = Astro.props;
const locale = lang === 'jp' ? 'ja' : 'en';
---
<a
  class="utau-card"
  href="https://utau.link"
  target="_blank"
  rel="noreferrer noopener"
  lang={locale}
  aria-label={`${title} - ${description}`}
>
  <div class="utau-card-inner">
    <span class="utau-version" data-i18n="utau.version">{version}</span>

    <div class="utau-copy">
      <h2 class="utau-title" data-i18n="utau.title">{title}</h2>
      <p class="utau-description" data-i18n="utau.subtitle">{description}</p>
    </div>

    <span class="utau-corner-arrow" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none">
        <path d="M5 15L15 5" />
        <path d="M8 5H15V12" />
      </svg>
    </span>
  </div>
</a>

<style>
  .utau-card {
    width: 100%;
    display: block;
    text-align: left;
    color: #ffffff;
    text-decoration: none;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0) 36%),
      linear-gradient(145deg, #9ec2e0 0%, #87acd1 56%, #7597c1 100%);
    border-radius: 26px;
    transition:
      transform 0.26s var(--project-card-hover-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      box-shadow 0.26s var(--project-card-hover-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      border-color 0.26s ease,
      opacity 0.36s ease,
      filter 0.48s ease,
      max-height 0.72s var(--project-stack-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      margin 0.56s var(--project-stack-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      visibility 0s linear 0s;
    box-shadow: 0 14px 28px rgba(90, 129, 171, 0.13);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    position: relative;
    transform-origin: top center;
    will-change: transform, box-shadow, opacity, filter, max-height;
    max-height: 280px;
  }

  .utau-card:hover {
    transform: var(--project-card-hover-transform, translateY(-2px) scale(1.008));
    box-shadow: 0 20px 34px rgba(90, 129, 171, 0.18);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .utau-card:hover .utau-corner-arrow {
    transform: translate(2px, -2px);
    opacity: 1;
  }

  .utau-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
    pointer-events: none;
  }

  .utau-card-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 24px 26px 22px;
    min-height: 220px;
    position: relative;
    z-index: 1;
  }

  .utau-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    width: min(100%, 500px);
  }

  .utau-title {
    margin: 0;
    font-size: clamp(2rem, 4.1vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.95;
    color: #ffffff;
  }

  .utau-version {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .utau-description {
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.92;
    margin: 0;
    max-width: 34ch;
  }

  .utau-corner-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    position: absolute;
    right: 24px;
    bottom: 24px;
    opacity: 0.72;
    transition:
      transform 0.26s var(--project-card-hover-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      opacity 0.26s ease;
  }

  .utau-corner-arrow svg {
    width: 100%;
    height: 100%;
  }

  .utau-corner-arrow path {
    stroke: rgba(255, 255, 255, 0.88);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 640px) {
    .utau-card {
      border-radius: 22px;
    }

    .utau-card-inner {
      padding: 18px;
      min-height: 0;
    }

    .utau-description {
      max-width: none;
    }

    .utau-corner-arrow {
      right: 18px;
      bottom: 18px;
      width: 18px;
      height: 18px;
    }
  }
</style>
