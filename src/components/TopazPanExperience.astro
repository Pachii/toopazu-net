---
import TopazPanCard from './TopazPanCard.astro';
import TopazPanPage from './TopazPanPage.astro';
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  title: string;
  description: string;
  version: string;
  initialOpen?: boolean;
  initialHidden?: boolean;
}

const { lang, title, description, version, initialOpen = false, initialHidden = false } = Astro.props;
---
<section
  class={`topaz-pan-experience ${initialOpen ? 'is-focused-project' : ''} ${initialHidden ? 'is-hidden-project' : ''}`}
  data-topaz-pan-experience
  data-project-route="pan"
>
  <div class={`topaz-pan-shell ${initialOpen ? 'is-open' : ''}`} data-topaz-shell>
    <div class="topaz-pan-compact">
      <TopazPanCard
        lang={lang}
        title={title}
        description={description}
        version={version}
      />
    </div>

    <div class="topaz-pan-expanded">
      <div class="topaz-pan-expanded-inner">
        <TopazPanPage lang={lang} version={version} />
      </div>
    </div>
  </div>
</section>

<style>
  .topaz-pan-experience {
    margin-top: 4px;
    animation: fadeIn 0.6s ease forwards;
  }

  .topaz-pan-shell {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: visible;
    z-index: 0;
  }

  .topaz-pan-shell.is-open,
  .topaz-pan-shell.is-closing {
    z-index: 2;
  }

  .topaz-pan-compact {
    position: relative;
    z-index: 2;
    transform-origin: top center;
    transition:
      opacity 0.26s ease,
      transform 0.52s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.36s ease;
    will-change: opacity, transform, filter;
  }

  .topaz-pan-expanded {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(22px) scale(0.985);
    transform-origin: top center;
    transition:
      grid-template-rows 0.62s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease,
      transform 0.62s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform, grid-template-rows;
  }

  .topaz-pan-expanded-inner {
    min-height: 0;
    overflow: hidden;
  }

  .topaz-pan-shell.is-open,
  .topaz-pan-shell.is-closing {
    min-height: var(--topaz-pan-compact-height, 220px);
  }

  .topaz-pan-shell.is-open .topaz-pan-compact {
    position: absolute;
    inset: 0 0 auto 0;
    opacity: 0;
    transform: translateY(-18px) scale(0.97);
    pointer-events: none;
    filter: blur(8px);
  }

  .topaz-pan-shell.is-closing .topaz-pan-compact {
    position: absolute;
    inset: 0 0 auto 0;
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: none;
    filter: blur(0);
  }

  .topaz-pan-shell.is-open .topaz-pan-expanded,
  .topaz-pan-shell.is-closing .topaz-pan-expanded {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: translateY(0);
  }

  .topaz-pan-shell.is-closing .topaz-pan-expanded {
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(20px) scale(0.985);
  }

  @media (prefers-reduced-motion: reduce) {
    .topaz-pan-compact,
    .topaz-pan-expanded {
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const normalizeTopazLang = (value) => value === 'ja' || value === 'jp' ? 'jp' : 'en';
    const getProjectRouteFromPath = (pathname) => {
      const segments = pathname.replace(/\/+$/, '').split('/').filter(Boolean);

      if (segments[0] === 'en' || segments[0] === 'jp' || segments[0] === 'ja') {
        segments.shift();
      }

      return segments[0] === 'pan' || segments[0] === 'dam-vision' ? segments[0] : '';
    };

    const syncProjectStack = (root, preferredRoute = null) => {
      const stack = root.closest('.projects-view');
      if (!(stack instanceof HTMLElement)) return;

      const experiences = stack.querySelectorAll('[data-project-route]');
      const openShell = stack.querySelector('.topaz-pan-shell.is-open, .dam-shell.is-open');
      const fallbackRoute = openShell?.closest('[data-project-route]')?.dataset.projectRoute ?? '';
      const activeRoute = typeof preferredRoute === 'string'
        ? preferredRoute
        : stack.dataset.activeProject || fallbackRoute;
      const hasOpenProject = Boolean(activeRoute);

      if (activeRoute) {
        stack.dataset.activeProject = activeRoute;
      } else {
        delete stack.dataset.activeProject;
      }

      experiences.forEach((experience) => {
        const isFocused = hasOpenProject && experience.dataset.projectRoute === activeRoute;
        experience.classList.toggle('is-focused-project', isFocused);
        experience.classList.toggle('is-hidden-project', hasOpenProject && !isFocused);
      });
    };

    const getLocalizedProjectPath = (pathname, target) => {
      const segments = pathname.replace(/\/+$/, '').split('/').filter(Boolean);
      let lang = '';

      if (segments[0] === 'en' || segments[0] === 'jp' || segments[0] === 'ja') {
        lang = normalizeTopazLang(segments.shift());
      }

      const prefix = lang ? `/${lang}` : '';
      return target === 'pan' ? `${prefix}/pan` : `${prefix}/software`;
    };

    const syncTopazPanels = () => {
      document.querySelectorAll('[data-topaz-pan-experience]').forEach(root => {
        if (root.dataset.topazReady === 'true') return;
        root.dataset.topazReady = 'true';

        const shell = root.querySelector('[data-topaz-shell]');
        const openButton = root.querySelector('[data-topaz-open]');
        const closeButton = root.querySelector('[data-topaz-close]');
        const compact = root.querySelector('.topaz-pan-compact');

        if (!shell || !openButton || !closeButton || !(compact instanceof HTMLElement)) return;

        let closeTimer = 0;
        let compactHeightObserver;

        const syncCompactHeight = () => {
          shell.style.setProperty('--topaz-pan-compact-height', `${compact.getBoundingClientRect().height}px`);
        };

        if ('ResizeObserver' in window) {
          compactHeightObserver = new ResizeObserver(syncCompactHeight);
          compactHeightObserver.observe(compact);
        } else {
          window.addEventListener('resize', syncCompactHeight);
        }
        syncCompactHeight();

        const setOpen = (open, pushHistory = false, immediate = false, activeRoute = open ? 'pan' : null) => {
          window.clearTimeout(closeTimer);

          if (open) {
            shell.classList.remove('is-closing');
            shell.classList.add('is-open');
          } else if (immediate) {
            document.dispatchEvent(new CustomEvent('topaz-pan-close'));
            shell.classList.remove('is-open');
            shell.classList.remove('is-closing');
          } else {
            document.dispatchEvent(new CustomEvent('topaz-pan-close'));
            shell.classList.add('is-closing');
            shell.classList.remove('is-open');
            closeTimer = window.setTimeout(() => {
              shell.classList.remove('is-closing');
            }, 620);
          }

          openButton.setAttribute('aria-expanded', open ? 'true' : 'false');
          if (activeRoute === null) {
            syncProjectStack(root);
          } else {
            syncProjectStack(root, activeRoute);
          }

          if (pushHistory) {
            const nextPath = getLocalizedProjectPath(window.location.pathname, open ? 'pan' : 'software');
            if (window.location.pathname !== nextPath) {
              window.history.pushState({ topazPanOpen: open }, '', nextPath);
            }
          }
        };

        const syncWithLocation = (nextPath = window.location.pathname) => {
          const path = nextPath.replace(/\/+$/, '');
          const activeRoute = getProjectRouteFromPath(path);
          setOpen(activeRoute === 'pan', false, root.dataset.topazSynced !== 'true', activeRoute);
          root.dataset.topazSynced = 'true';
        };

        const handleAppRouteChange = (event) => {
          const nextPath = event.detail?.pathname || window.location.pathname;
          syncWithLocation(nextPath);
        };

        openButton.addEventListener('click', () => {
          syncProjectStack(root, 'pan');
          document.dispatchEvent(new CustomEvent('project-panel-open', { detail: { route: 'pan' } }));
          window.requestAnimationFrame(() => {
            setOpen(true, true, false, 'pan');
          });
        });
        closeButton.addEventListener('click', () => {
          syncProjectStack(root, '');
          setOpen(false, true, false, '');
        });
        document.addEventListener('project-panel-open', (event) => {
          if (event.detail?.route !== 'pan') {
            setOpen(false, false, true, event.detail?.route ?? '');
          }
        });
        document.addEventListener('app-route-change', handleAppRouteChange);
        window.addEventListener('popstate', syncWithLocation);
        syncWithLocation();
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', syncTopazPanels);
    } else {
      syncTopazPanels();
    }
  })();
</script>
