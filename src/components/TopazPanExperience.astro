---
import TopazPanCard from './TopazPanCard.astro';
import TopazPanPage from './TopazPanPage.astro';
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  title: string;
  description: string;
  version: string;
  initialOpen?: boolean;
  initialHidden?: boolean;
}

const { lang, title, description, version, initialOpen = false, initialHidden = false } = Astro.props;
---
<section
  class={`topaz-pan-experience ${initialOpen ? 'is-focused-project' : ''} ${initialHidden ? 'is-hidden-project' : ''}`}
  data-project-panel
  data-project-route="pan"
  data-project-close-event="topaz-pan-close"
>
  <div class={`topaz-pan-shell ${initialOpen ? 'is-open' : ''}`} data-project-shell>
    <div class="topaz-pan-compact" data-project-compact>
      <TopazPanCard
        lang={lang}
        title={title}
        description={description}
        version={version}
      />
    </div>

    <div class="topaz-pan-expanded">
      <div class="topaz-pan-expanded-inner">
        <TopazPanPage lang={lang} version={version} />
      </div>
    </div>
  </div>
</section>

<style>
  .topaz-pan-experience {
    animation: fadeIn 0.6s ease forwards;
  }

  .topaz-pan-shell {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: visible;
    z-index: 0;
  }

  .topaz-pan-shell.is-open,
  .topaz-pan-shell.is-closing {
    z-index: 2;
  }

  .topaz-pan-compact {
    position: relative;
    z-index: 2;
    transform-origin: top center;
    transition:
      opacity 0.34s ease,
      transform 0.64s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.46s ease;
    will-change: opacity, transform, filter;
  }

  .topaz-pan-expanded {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(18px) scale(0.99);
    transform-origin: top center;
    transition:
      grid-template-rows 0.66s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.48s ease,
      transform 0.66s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform, grid-template-rows;
  }

  .topaz-pan-expanded-inner {
    min-height: 0;
    overflow: hidden;
  }

  .topaz-pan-shell.is-open,
  .topaz-pan-shell.is-closing {
    min-height: var(--project-compact-height, 220px);
  }

  .topaz-pan-shell.is-open .topaz-pan-compact {
    position: absolute;
    inset: 0 0 auto 0;
    opacity: 0;
    transform: translateY(-14px) scale(0.982);
    pointer-events: none;
    filter: blur(6px);
  }

  .topaz-pan-shell.is-closing .topaz-pan-compact {
    position: absolute;
    inset: 0 0 auto 0;
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: none;
    filter: blur(0);
    transition-delay: 0.1s, 0.1s, 0.1s;
  }

  .topaz-pan-shell.is-open .topaz-pan-expanded,
  .topaz-pan-shell.is-closing .topaz-pan-expanded {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: translateY(0);
  }

  .topaz-pan-shell.is-closing .topaz-pan-expanded {
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(14px) scale(0.992);
  }

  @media (prefers-reduced-motion: reduce) {
    .topaz-pan-compact,
    .topaz-pan-expanded {
      transition: none;
    }
  }
</style>
