---
import TopazPanCard from './TopazPanCard.astro';
import TopazPanPage from './TopazPanPage.astro';
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  title: string;
  description: string;
  version: string;
  initialOpen?: boolean;
}

const { lang, title, description, version, initialOpen = false } = Astro.props;
---
<section class="topaz-pan-experience" data-topaz-pan-experience>
  <div class={`topaz-pan-shell ${initialOpen ? 'is-open' : ''}`} data-topaz-shell>
    <div class="topaz-pan-compact">
      <TopazPanCard
        lang={lang}
        title={title}
        description={description}
        version={version}
      />
    </div>

    <div class="topaz-pan-expanded">
      <div class="topaz-pan-expanded-inner">
        <TopazPanPage lang={lang} version={version} />
      </div>
    </div>
  </div>
</section>

<style>
  .topaz-pan-experience {
    margin-top: 4px;
    animation: fadeIn 0.6s ease forwards;
  }

  .topaz-pan-shell {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .topaz-pan-compact {
    position: relative;
    z-index: 2;
    transform-origin: top center;
    transition: opacity 0.28s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), filter 0.28s ease;
  }

  .topaz-pan-expanded {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(16px);
    transition:
      grid-template-rows 0.52s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.32s ease,
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .topaz-pan-expanded-inner {
    min-height: 0;
    overflow: hidden;
  }

  .topaz-pan-shell.is-open .topaz-pan-compact {
    position: absolute;
    inset: 0 0 auto 0;
    opacity: 0;
    transform: translateY(-14px) scale(0.985);
    pointer-events: none;
    filter: blur(1px);
  }

  .topaz-pan-shell.is-closing .topaz-pan-compact {
    position: absolute;
    inset: 0 0 auto 0;
    opacity: 0;
    transform: translateY(-14px) scale(0.985);
    pointer-events: none;
    filter: blur(1px);
  }

  .topaz-pan-shell.is-open .topaz-pan-expanded {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .topaz-pan-compact,
    .topaz-pan-expanded {
      transition: none;
    }
  }
</style>

<script is:inline>
  const normalizeTopazLang = (value) => value === 'ja' || value === 'jp' ? 'jp' : 'en';

  const getLocalizedProjectPath = (pathname, target) => {
    const segments = pathname.replace(/\/+$/, '').split('/').filter(Boolean);
    let lang = '';

    if (segments[0] === 'en' || segments[0] === 'jp' || segments[0] === 'ja') {
      lang = normalizeTopazLang(segments.shift());
    }

    const prefix = lang ? `/${lang}` : '';
    return target === 'pan' ? `${prefix}/pan` : `${prefix}/software`;
  };

  const syncTopazPanels = () => {
    document.querySelectorAll('[data-topaz-pan-experience]').forEach(root => {
      if (root.dataset.topazReady === 'true') return;
      root.dataset.topazReady = 'true';

      const shell = root.querySelector('[data-topaz-shell]');
      const openButton = root.querySelector('[data-topaz-open]');
      const closeButton = root.querySelector('[data-topaz-close]');

      if (!shell || !openButton || !closeButton) return;

      let closeTimer = 0;

      const setOpen = (open, pushHistory = false, immediate = false) => {
        window.clearTimeout(closeTimer);

        if (open) {
          shell.classList.remove('is-closing');
          shell.classList.add('is-open');
        } else if (immediate) {
          document.dispatchEvent(new CustomEvent('topaz-pan-close'));
          shell.classList.remove('is-open');
          shell.classList.remove('is-closing');
        } else {
          document.dispatchEvent(new CustomEvent('topaz-pan-close'));
          shell.classList.add('is-closing');
          shell.classList.remove('is-open');
          closeTimer = window.setTimeout(() => {
            shell.classList.remove('is-closing');
          }, 360);
        }

        openButton.setAttribute('aria-expanded', open ? 'true' : 'false');

        if (pushHistory) {
          const nextPath = getLocalizedProjectPath(window.location.pathname, open ? 'pan' : 'software');
          if (window.location.pathname !== nextPath) {
            window.history.pushState({ topazPanOpen: open }, '', nextPath);
          }
        }
      };

      const syncWithLocation = () => {
        const path = window.location.pathname.replace(/\/+$/, '');
        setOpen(path.endsWith('/pan'), false, root.dataset.topazSynced !== 'true');
        root.dataset.topazSynced = 'true';
      };

      openButton.addEventListener('click', () => setOpen(true, true));
      closeButton.addEventListener('click', () => setOpen(false, true));
      window.addEventListener('popstate', syncWithLocation);
      syncWithLocation();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', syncTopazPanels);
  } else {
    syncTopazPanels();
  }
</script>
