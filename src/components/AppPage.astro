---
import Layout from './Layout.astro';
import ProfileHeader from './ProfileHeader.astro';
import SocialIconRow from './SocialIconRow.astro';
import TabSwitcher from './TabSwitcher.astro';
import FeaturedCard from './FeaturedCard.astro';
import TopazPanCard from './TopazPanCard.astro';
import CommissionCard from './CommissionCard.astro';
import PreviousWorksCarousel from './PreviousWorksCarousel.astro';
import MixedWorksList from './MixedWorksList.astro';

import { defaultLang, ui } from '../i18n/ui';
import { profileInfo, socialLinks, featuredData } from '../data/profile';
import { getTopazPanVersion } from '../utils/github';
import { getPlaylistVideos } from '../utils/youtube';
import type { AppLang } from '../i18n/utils';

interface Props {
  forcedLang?: AppLang;
}

const { forcedLang } = Astro.props;
const serverLang = forcedLang ?? defaultLang;
const t = (key: keyof typeof ui['en']) => ui[serverLang][key];

const videos = await getPlaylistVideos('PLBRf9rHBrMc-4bXWqTUBIUfmRRw7Sjzy-');
const mixedVideos = await getPlaylistVideos('PLBRf9rHBrMc9JkiqjyOp7BOQLBSIeRCfV');
const topazPanVersion = await getTopazPanVersion();
const latestVideo = videos.length > 0 ? videos[0] : null;
const previousVideos = videos.length > 1 ? videos.slice(1) : [];

const featuredImage = latestVideo ? `https://img.youtube.com/vi/${latestVideo.id}/maxresdefault.jpg` : featuredData.imageUrl;
const featuredUrl = latestVideo ? `https://youtube.com/watch?v=${latestVideo.id}` : featuredData.videoUrl;

const clientTranslations = JSON.parse(JSON.stringify(ui)) as typeof ui;
if (latestVideo && latestVideo.titles) {
  clientTranslations.en['video.title'] = latestVideo.titles.en;
  if (clientTranslations.jp) clientTranslations.jp['video.title'] = latestVideo.titles.ja;
}

previousVideos.forEach(v => {
  clientTranslations.en[`video-${v.id}`] = v.titles.en;
  if (clientTranslations.jp) clientTranslations.jp[`video-${v.id}`] = v.titles.ja;
});

mixedVideos.forEach(v => {
  clientTranslations.en[`mixed-video-${v.id}`] = v.titles.en;
  clientTranslations.en[`mixed-author-${v.id}`] = v.authors.en;
  if (clientTranslations.jp) clientTranslations.jp[`mixed-video-${v.id}`] = v.titles.ja;
  if (clientTranslations.jp) clientTranslations.jp[`mixed-author-${v.id}`] = v.authors.ja;
});

const featuredTitle = t('featured.badge');
const featuredI18nKey = 'featured.badge';
const videoTitle = latestVideo ? clientTranslations[serverLang]['video.title'] : '';
const pathname = Astro.url.pathname.replace(/\/$/, '');
const initialView = pathname.endsWith('/software') || pathname.endsWith('/pan')
  ? 'projects-view'
  : pathname.endsWith('/commission')
    ? 'commission-view'
    : 'links-view';
const visibleStyle = 'display: block; opacity: 1; transform: translateY(0);';
const hiddenStyle = 'display: none; opacity: 0; transform: translateY(10px);';
---
<Layout title="とぱず / topaz" currentLang={serverLang}>
  <script is:inline define:vars={{ translations: clientTranslations, defaultLang, forcedLang }}>
    const normalizeLanguage = (value) => value === 'ja' || value === 'jp' ? 'jp' : 'en';
    const getHtmlLang = (lang) => lang === 'jp' ? 'ja' : 'en';

    const getRouteInfo = (pathname = window.location.pathname) => {
      const segments = pathname.replace(/\/+$/, '').split('/').filter(Boolean);
      let routeLang = null;

      if (segments[0] === 'en' || segments[0] === 'jp' || segments[0] === 'ja') {
        routeLang = normalizeLanguage(segments.shift());
      }

      let view = 'links-view';
      if (segments[0] === 'software' || segments[0] === 'pan') {
        view = 'projects-view';
      } else if (segments[0] === 'commission') {
        view = 'commission-view';
      }

      return { routeLang, view };
    };

    const buildPath = (view, lang = '') => {
      const prefix = lang ? `/${lang}` : '';
      const suffix = view === 'projects-view'
        ? '/software'
        : view === 'commission-view'
          ? '/commission'
          : '';

      return `${prefix}${suffix}` || '/';
    };

    window.translations = translations;

    const getInitialLanguage = () => {
      const { routeLang } = getRouteInfo();
      let lang = forcedLang || routeLang || localStorage.getItem('preferred-language');

      if (!lang) {
        const browserLang = navigator.language || navigator.userLanguage || '';
        lang = normalizeLanguage(browserLang.split('-')[0].toLowerCase());
      }

      return normalizeLanguage(lang);
    };

    const initialLanguage = getInitialLanguage();
    document.documentElement.lang = getHtmlLang(initialLanguage);

    window.setLanguage = function(lang, animate = true) {
      lang = normalizeLanguage(lang);
      if (!translations[lang]) return;

      localStorage.setItem('preferred-language', lang);

      const targetEls = document.querySelectorAll('[data-i18n], .commission-card');

      const applyLanguage = () => {
        document.documentElement.lang = getHtmlLang(lang);

        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          if (translations[lang] && translations[lang][key]) {
            el.textContent = translations[lang][key];
          }
        });

        document.querySelectorAll('.lang-btn').forEach(btn => {
          if (btn.getAttribute('data-lang') === lang) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      };

      if (animate) {
        targetEls.forEach(el => {
          el.style.transition = 'opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out';
          el.style.opacity = '0';
          el.style.transform = 'translateY(4px)';
          el.style.filter = 'blur(2px)';
        });

        setTimeout(() => {
          applyLanguage();

          targetEls.forEach(el => {
            el.style.transition = 'none';
            el.style.transform = 'translateY(-4px)';
            void el.offsetWidth;
            el.style.transition = 'opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            el.style.filter = 'blur(0px)';
          });
        }, 150);
      } else {
        applyLanguage();
      }
    };

    window.switchLanguageRoute = function(nextLang) {
      const lang = normalizeLanguage(nextLang);
      const { view } = getRouteInfo();

      localStorage.setItem('preferred-language', lang);
      window.location.pathname = buildPath(view, lang);
    };

    document.addEventListener("DOMContentLoaded", () => {
      if (typeof window.setLanguage === 'function') {
        window.setLanguage(initialLanguage, false);
      }
    });
  </script>

  <style is:global>
    [data-i18n] {
      transition: opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out;
    }
  </style>

  <ProfileHeader
    name={profileInfo.name}
    handle={profileInfo.handle}
    roleText={t('profile.role')}
    avatarUrl={profileInfo.avatarUrl}
  />
  <SocialIconRow links={socialLinks} t={t} />

  <TabSwitcher
    tab1={t('tab.main')}
    tab2={t('tab.special')}
    tab3={t('tab.commission')}
    initialTarget={initialView}
  />
  
  <div class="tabs-content">
    <div id="links-view" class="tab-view" style={initialView === 'links-view' ? visibleStyle : hiddenStyle}>
      <FeaturedCard
        imageUrl={featuredImage}
        altText={featuredData.altText}
        url={featuredUrl}
        badgeText={featuredTitle}
        badgeI18nKey={featuredI18nKey}
        videoTitle={videoTitle}
        videoTitleI18nKey="video.title"
      />
      <PreviousWorksCarousel 
        videos={previousVideos}
        titleI18nKey="previous.works"
        titleText={t('previous.works')}
        defaultLang={serverLang}
      />
      <MixedWorksList
        videos={mixedVideos}
        titleI18nKey="mixed.works"
        titleText={t('mixed.works')}
        defaultLang={serverLang}
      />
    </div>

    <div id="commission-view" class="tab-view" style={initialView === 'commission-view' ? visibleStyle : hiddenStyle}>
      <CommissionCard />
    </div>

    <div id="projects-view" class="tab-view" style={initialView === 'projects-view' ? visibleStyle : hiddenStyle}>
      <TopazPanCard 
        title={t('project.title')} 
        description={t('project.subtitle')} 
        version={topazPanVersion}
        githubText={t('project.github')} 
      />
    </div>
  </div>
</Layout>

<style>
  .tabs-content {
    position: relative;
    width: 100%;
  }

  .tab-view {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
</style>
