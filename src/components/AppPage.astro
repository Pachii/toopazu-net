---
import Layout from './Layout.astro';
import ProfileHeader from './ProfileHeader.astro';
import SocialIconRow from './SocialIconRow.astro';
import TabSwitcher from './TabSwitcher.astro';
import FeaturedCard from './FeaturedCard.astro';
import TopazPanExperience from './TopazPanExperience.astro';
import DamVisionExperience from './DamVisionExperience.astro';
import CommissionCard from './CommissionCard.astro';
import PreviousWorksCarousel from './PreviousWorksCarousel.astro';
import MixedWorksList from './MixedWorksList.astro';

import { defaultLang, ui } from '../i18n/ui';
import { parseAppPath } from '../utils/appRoutes';
import { profileInfo, socialLinks, featuredData } from '../data/profile';
import { getTopazPanVersion } from '../utils/github';
import { getPlaylistVideos } from '../utils/youtube';
import type { AppLang } from '../i18n/utils';

interface Props {
  forcedLang?: AppLang;
}

const { forcedLang } = Astro.props;
const serverLang = forcedLang ?? defaultLang;
const t = (key: keyof typeof ui['en']) => ui[serverLang][key];

const videos = await getPlaylistVideos('PLBRf9rHBrMc-4bXWqTUBIUfmRRw7Sjzy-');
const mixedVideos = await getPlaylistVideos('PLBRf9rHBrMc9JkiqjyOp7BOQLBSIeRCfV');
const topazPanVersion = await getTopazPanVersion();
const latestVideo = videos.length > 0 ? videos[0] : null;
const previousVideos = videos.length > 1 ? videos.slice(1) : [];

const featuredImage = latestVideo ? `https://img.youtube.com/vi/${latestVideo.id}/maxresdefault.jpg` : featuredData.imageUrl;
const featuredUrl = latestVideo ? `https://youtube.com/watch?v=${latestVideo.id}` : featuredData.videoUrl;

const clientTranslations = JSON.parse(JSON.stringify(ui)) as typeof ui;
if (latestVideo && latestVideo.titles) {
  clientTranslations.en['video.title'] = latestVideo.titles.en;
  if (clientTranslations.jp) clientTranslations.jp['video.title'] = latestVideo.titles.ja;
}

previousVideos.forEach(v => {
  clientTranslations.en[`video-${v.id}`] = v.titles.en;
  if (clientTranslations.jp) clientTranslations.jp[`video-${v.id}`] = v.titles.ja;
});

mixedVideos.forEach(v => {
  clientTranslations.en[`mixed-video-${v.id}`] = v.titles.en;
  clientTranslations.en[`mixed-author-${v.id}`] = v.authors.en;
  if (clientTranslations.jp) clientTranslations.jp[`mixed-video-${v.id}`] = v.titles.ja;
  if (clientTranslations.jp) clientTranslations.jp[`mixed-author-${v.id}`] = v.authors.ja;
});

const featuredTitle = t('featured.badge');
const featuredI18nKey = 'featured.badge';
const videoTitle = latestVideo ? clientTranslations[serverLang]['video.title'] : '';
const routeInfo = parseAppPath(Astro.url.pathname);
const initialView = routeInfo.view;
const initialTopazOpen = routeInfo.activeProjectRoute === 'pan';
const initialDamOpen = routeInfo.activeProjectRoute === 'dam-vision';
const initialActiveProject = routeInfo.activeProjectRoute;
const appPageState = JSON.stringify({
  forcedLang,
  translations: clientTranslations,
}).replace(/</g, '\\u003c');
const visibleStyle = 'display: block; opacity: 1; transform: translateY(0);';
const hiddenStyle = 'display: none; opacity: 0; transform: translateY(10px);';
---
<Layout title="とぱず / topaz" currentLang={serverLang}>
  <script type="application/json" data-app-page-state set:html={appPageState}></script>
  <script>
    import { setupAppPage } from '../scripts/setupAppPage';

    setupAppPage();
  </script>

  <style is:global>
    [data-i18n] {
      transition: opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out;
    }
  </style>

  <ProfileHeader
    name={profileInfo.name}
    handle={profileInfo.handle}
    roleText={t('profile.role')}
    avatarUrl={profileInfo.avatarUrl}
  />
  <SocialIconRow links={socialLinks} t={t} />

  <TabSwitcher
    tab1={t('tab.main')}
    tab2={t('tab.special')}
    tab3={t('tab.commission')}
    initialTarget={initialView}
  />
  
  <div class="tabs-content">
    <div id="links-view" class="tab-view" style={initialView === 'links-view' ? visibleStyle : hiddenStyle}>
      <FeaturedCard
        imageUrl={featuredImage}
        altText={featuredData.altText}
        url={featuredUrl}
        badgeText={featuredTitle}
        badgeI18nKey={featuredI18nKey}
        videoTitle={videoTitle}
        videoTitleI18nKey="video.title"
      />
      <PreviousWorksCarousel 
        videos={previousVideos}
        titleI18nKey="previous.works"
        titleText={t('previous.works')}
        defaultLang={serverLang}
      />
      <MixedWorksList
        videos={mixedVideos}
        titleI18nKey="mixed.works"
        titleText={t('mixed.works')}
        defaultLang={serverLang}
      />
    </div>

    <div id="commission-view" class="tab-view" style={initialView === 'commission-view' ? visibleStyle : hiddenStyle}>
      <CommissionCard />
    </div>

    <div
      id="projects-view"
      class="tab-view projects-view"
      style={initialView === 'projects-view' ? visibleStyle : hiddenStyle}
      data-project-stack
      data-active-project={initialActiveProject || undefined}
      data-stack-mode={initialActiveProject ? 'focused' : 'list'}
    >
      <TopazPanExperience
        lang={serverLang}
        title={t('project.title')} 
        description={t('project.subtitle')} 
        version={topazPanVersion}
        initialOpen={initialTopazOpen}
        initialHidden={initialDamOpen}
      />

      <DamVisionExperience
        lang={serverLang}
        title={t('dam.title')}
        description={t('dam.subtitle')}
        version={t('dam.version')}
        initialOpen={initialDamOpen}
        initialHidden={initialTopazOpen}
      />
    </div>
  </div>
</Layout>

<style>
  .tabs-content {
    position: relative;
    width: 100%;
  }

  .tab-view {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .projects-view {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    isolation: isolate;
    --project-card-hover-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --project-card-hover-transform: translateY(-2px) scale(1.008);
    --project-stack-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --project-stack-return-ease: cubic-bezier(0.18, 1, 0.32, 1);
    --project-stack-hidden-shift: 16px;
    --project-stack-hidden-scale: 0.978;
  }
</style>

<style is:global>
  .projects-view > [data-project-route] {
    position: relative;
    margin-top: 0;
    transition:
      opacity 0.36s ease,
      transform 0.72s var(--project-stack-ease),
      filter 0.48s ease,
      max-height 0.72s var(--project-stack-ease),
      margin 0.56s var(--project-stack-ease),
      visibility 0s linear 0s;
    max-height: 2400px;
    transform-origin: top center;
    will-change: opacity, transform, filter, max-height;
  }

  .projects-view[data-stack-phase='returning'] > [data-project-route] {
    transition:
      opacity 0.42s ease,
      transform 0.82s var(--project-stack-return-ease),
      filter 0.52s ease,
      max-height 0.82s var(--project-stack-return-ease),
      margin 0.74s var(--project-stack-return-ease),
      visibility 0s linear 0s;
  }

  .projects-view[data-stack-phase='returning'] > [data-project-route]:not(.is-hidden-project) {
    transition-delay: 0.06s, 0.06s, 0.04s, 0s, 0s;
  }

  .projects-view[data-stack-mode='list'] > .topaz-pan-experience {
    margin-top: 4px;
  }

  .projects-view[data-stack-mode='list'] > .dam-experience {
    margin-top: 20px;
  }

  .projects-view > .is-focused-project {
    z-index: 1;
  }

  .projects-view > .is-hidden-project {
    opacity: 0;
    filter: blur(12px) saturate(0.82);
    max-height: 0;
    overflow: hidden;
    margin: 0;
    pointer-events: none;
    visibility: hidden;
    transition-delay: 0s, 0s, 0s, 0s, 0.62s;
  }

  .projects-view > .is-hidden-project[data-project-relation='before'] {
    transform: translateY(calc(var(--project-stack-hidden-shift) * -1)) scale(var(--project-stack-hidden-scale));
  }

  .projects-view > .is-hidden-project[data-project-relation='after'] {
    transform: translateY(var(--project-stack-hidden-shift)) scale(var(--project-stack-hidden-scale));
  }

  .projects-view[data-stack-mode='focused'] > .is-focused-project {
    z-index: 2;
  }

  @media (prefers-reduced-motion: reduce) {
    .projects-view,
    .projects-view > [data-project-route] {
      transition: none;
    }
  }
</style>
