---
import { getHtmlLang, getLangFromUrl } from '../i18n/utils';
import { languages } from '../i18n/ui';
import '../styles/global.css';
import LanguageToggle from './LanguageToggle.astro';
import type { AppLang } from '../i18n/utils';

interface Props {
  title: string;
  currentLang?: AppLang;
}

const { title, currentLang } = Astro.props;
const lang = currentLang ?? getLangFromUrl(Astro.url);
---
<!doctype html>
<html lang={getHtmlLang(lang)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="歌、mix & master" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="container animate-fade-in">
      <LanguageToggle currentLang={lang} languages={languages} />
      <slot />
    </div>
  </body>
</html>
