---
interface Props {
  offLabel: string;
  onLabel: string;
}

const { offLabel, onLabel } = Astro.props;
---
<div class="plugin-toggle" data-plugin-toggle>
  <button type="button" class="plugin-toggle-option is-active" data-plugin-state="off" aria-pressed="true">
    <span data-i18n="project.demo.plugin.off">{offLabel}</span>
  </button>
  <button type="button" class="plugin-toggle-option" data-plugin-state="on" aria-pressed="false">
    <span data-i18n="project.demo.plugin.on">{onLabel}</span>
  </button>
  <span class="plugin-toggle-slider" aria-hidden="true"></span>
</div>

<style>
  .plugin-toggle {
    position: relative;
    display: inline-grid;
    grid-template-columns: 1fr 1fr;
    padding: 4px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(121, 180, 201, 0.16);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.58);
    min-width: 220px;
  }

  .plugin-toggle-option {
    position: relative;
    z-index: 1;
    min-height: 40px;
    padding: 0 16px;
    border-radius: 999px;
    font-size: 0.86rem;
    font-weight: 700;
    color: #6f878f;
    transition: color 0.2s ease;
  }

  .plugin-toggle-option.is-active {
    color: #4f6f7c;
  }

  .plugin-toggle-slider {
    position: absolute;
    top: 4px;
    left: 4px;
    bottom: 4px;
    width: calc(50% - 4px);
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 10px 24px rgba(95, 144, 162, 0.14);
    transition: transform 0.22s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .plugin-toggle[data-state='on'] .plugin-toggle-slider {
    transform: translateX(100%);
  }
</style>
