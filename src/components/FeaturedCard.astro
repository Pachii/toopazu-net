---
interface Props {
  imageUrl: string;
  altText: string;
  url: string;
  badgeText: string;
  badgeI18nKey?: string;
}

const { imageUrl, altText, url, badgeText, badgeI18nKey } = Astro.props;
---
<a href={url} target="_blank" rel="noopener noreferrer" class="featured-card">
  <div class="image-wrapper">
    <img src={imageUrl} alt={altText} class="featured-image" />
  </div>
  <div class="caption">
    <p data-i18n={badgeI18nKey}>{badgeText}</p>
  </div>
</a>

<style>
  .featured-card {
    display: block;
    background-color: var(--card-bg);
    border-radius: var(--border-radius);
    overflow: hidden;
    margin-top: 32px;
    box-shadow: var(--card-shadow);
    transition: var(--transition);
    text-decoration: none;
  }

  .featured-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
  }

  .image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #ebebeb; /* Placeholder background */
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .caption {
    padding: 16px 20px;
  }

  .caption p {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-main);
  }
</style>
