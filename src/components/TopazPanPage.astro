---
import { Icon } from 'astro-icon/components';
import TopazPanHeroSection from './TopazPanHeroSection.astro';
import TopazPanDemoPlayer from './TopazPanDemoPlayer.astro';
import { ui } from '../i18n/ui';
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  version: string;
}

const { lang, version } = Astro.props;
const t = (key: keyof typeof ui['en']) => ui[lang][key];
---
<div class="topaz-pan-page">
  <div class="topaz-pan-rail topaz-pan-hero-wrap">
    <button type="button" class="topaz-pan-close" data-project-close>
      <Icon name="mdi:arrow-left" size={16} />
      <span data-i18n="project.close">{t('project.close')}</span>
    </button>

    <TopazPanHeroSection lang={lang} version={version} />
  </div>

  <div class="topaz-pan-rail topaz-pan-story-grid">
    <section class="pan-section panel-surface">
      <div class="pan-section-header">
        <p class="pan-section-kicker" data-i18n="project.concept.eyebrow">{t('project.concept.eyebrow')}</p>
        <h3 class="pan-section-title" data-i18n="project.concept.title">{t('project.concept.title')}</h3>
      </div>
      <p class="pan-copy">
        <span data-i18n="project.concept.body.before">{t('project.concept.body.before')}</span>
        <a
          class="pan-inline-link"
          href="https://youtu.be/pwHqy9cKi7c?t=2587"
          target="_blank"
          rel="noopener noreferrer"
          data-i18n="project.concept.body.link"
        >
          {t('project.concept.body.link')}
        </a>
        <span data-i18n="project.concept.body.after">{t('project.concept.body.after')}</span>
      </p>
    </section>

    <section class="pan-section panel-surface">
      <div class="pan-section-header">
        <p class="pan-section-kicker" data-i18n="project.why.eyebrow">{t('project.why.eyebrow')}</p>
        <h3 class="pan-section-title" data-i18n="project.why.title">{t('project.why.title')}</h3>
      </div>
      <p class="pan-copy" data-i18n="project.why.body">{t('project.why.body')}</p>
    </section>
  </div>

  <div class="topaz-pan-demo-rail">
    <TopazPanDemoPlayer lang={lang} />
  </div>
</div>

<style>
.topaz-pan-page {
  display: flex;
  flex-direction: column;
  gap: 24px;
  width: 100%;
}

.topaz-pan-rail {
  width: min(100%, 720px);
  margin: 0 auto;
}

.topaz-pan-demo-rail {
  width: min(100%, 760px);
  margin: 0 auto;
}

.topaz-pan-hero-wrap {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 20px 22px 24px;
  border-radius: 28px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.14)),
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0) 42%);
  border: 1px solid rgba(121, 180, 201, 0.18);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.3),
    0 18px 38px rgba(121, 180, 201, 0.1);
}

.topaz-pan-close {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  align-self: flex-start;
  min-height: 38px;
  padding: 0 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.84);
  border: 1px solid rgba(121, 180, 201, 0.16);
  color: #557d8c;
  font-size: 0.82rem;
  font-weight: 700;
  box-shadow: 0 10px 22px rgba(121, 180, 201, 0.08);
  transition: transform 0.18s ease, background-color 0.18s ease;
}

.topaz-pan-close:hover {
  transform: translateY(-1px);
  background: rgba(255, 255, 255, 0.96);
}

  .topaz-pan-story-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .pan-section-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pan-section-kicker {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b9aac;
    font-weight: 700;
  }

  .pan-section-title {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.45;
    color: #4f6f7c;
    font-weight: 700;
  }

  .panel-surface {
    padding: 18px 18px 20px;
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.16));
    border: 1px solid rgba(121, 180, 201, 0.16);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.26),
      0 12px 28px rgba(121, 180, 201, 0.08);
  }

  .pan-copy {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-main);
  }

  .pan-inline-link {
    color: #1f6fd6;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgba(31, 111, 214, 0.72);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 0.18em;
    transition: color 0.18s ease, text-decoration-color 0.18s ease;
  }

  .pan-inline-link:hover {
    color: #1658ae;
    text-decoration-color: rgba(22, 88, 174, 0.88);
  }

  @media (max-width: 720px) {
    .topaz-pan-rail,
    .topaz-pan-demo-rail {
      width: 100%;
    }

    .topaz-pan-hero-wrap {
      padding: 18px 16px 20px;
      border-radius: 24px;
    }

    .topaz-pan-story-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .panel-surface {
      padding: 16px 16px 18px;
      border-radius: 20px;
    }
  }
</style>
