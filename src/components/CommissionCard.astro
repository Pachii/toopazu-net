</style>

<script>
  const setupCommissionCards = () => {
    document.querySelectorAll('[data-commission-card]').forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.commissionReady === 'true') return;
      root.dataset.commissionReady = 'true';

      const overlay = root.querySelector<HTMLElement>('[data-equipment-overlay]');
      const openButtons = root.querySelectorAll<HTMLButtonElement>('[data-equipment-open]');
      const closeButton = root.querySelector<HTMLButtonElement>('[data-equipment-close]');

      if (!overlay) return;

      document.body.appendChild(overlay);

      const openModal = () => {
        overlay.classList.add('is-visible');
        document.body.style.overflow = 'hidden';
      };

      const closeModal = () => {
        overlay.classList.remove('is-visible');
        document.body.style.overflow = '';
      };

      openButtons.forEach((button) => {
        button.addEventListener('click', openModal);
      });

      closeButton?.addEventListener('click', closeModal);

      overlay.addEventListener('click', (event) => {
        if (event.target === overlay) {
          closeModal();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && overlay.classList.contains('is-visible')) {
          closeModal();
        }
      });
    });
  };

  setupCommissionCards();
</script>
