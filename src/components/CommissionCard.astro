  .equip-value {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: #333;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: right;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const overlay = document.getElementById("equipmentOverlay");
    const btns = document.querySelectorAll(".equipment-btn");
    const btnClose = document.getElementById("closeEquipmentModal");

    if (!overlay) return;

    // Move the overlay to document.body to escape any ancestor transform
    // (the tab-switcher applies transform to the commission-view container,
    // which breaks position:fixed for descendants)
    document.body.appendChild(overlay);

    const openModal = () => {
      overlay.classList.add("is-visible");
      document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
      overlay.classList.remove("is-visible");
      document.body.style.overflow = "";
    };

    btns.forEach((btn) => btn.addEventListener("click", openModal));
    if (btnClose) btnClose.addEventListener("click", closeModal);

    // Close on overlay/backdrop click
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeModal();
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay.classList.contains("is-visible")) {
        closeModal();
      }
    });
  });
</script>
