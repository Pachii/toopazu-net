---
import { Icon } from 'astro-icon/components';
import { damVisionLinks } from '../data/damVision';
import { ui } from '../i18n/ui';
import type { AppLang } from '../i18n/utils';

interface Props {
  lang: AppLang;
  version: string;
}

const { lang, version } = Astro.props;
const t = (key: keyof typeof ui['en']) => ui[lang][key];
---
<div class="dam-hero">
  <div class="dam-hero-copy">
    <div class="dam-hero-head">
      <div class="dam-hero-title-block">
        <h2 class="dam-hero-title" data-i18n="dam.title">{t('dam.title')}</h2>
      </div>

      <div class="dam-hero-meta">
        <span class="dam-hero-version" data-i18n="dam.version">{version}</span>
        <div class="dam-hero-meta-pills">
          <span class="dam-hero-meta-pill" data-i18n="project.meta.opensource">{t('project.meta.opensource')}</span>
          <span class="dam-hero-meta-pill" data-i18n="project.meta.free">{t('project.meta.free')}</span>
        </div>
      </div>
    </div>

    <p class="dam-hero-body" data-i18n="dam.hero.body">{t('dam.hero.body')}</p>

    <div class="dam-hero-specs">
      <span class="dam-hero-spec-pill" data-i18n="dam.meta.type">{t('dam.meta.type')}</span>
      <span class="dam-hero-spec-pill" data-i18n="dam.meta.platforms">{t('dam.meta.platforms')}</span>
    </div>

    <div class="dam-hero-actions">
      <a href={damVisionLinks.development} target="_blank" rel="noopener noreferrer" class="dam-hero-button">
        <Icon name="simple-icons:x" size={16} />
        <span data-i18n="dam.follow">{t('dam.follow')}</span>
      </a>
    </div>
  </div>
</div>

<style>
  .dam-hero-copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
    width: 100%;
    max-width: none;
  }

  .dam-hero-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px 22px;
  }

  .dam-hero-title-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
    flex: 1 1 auto;
  }

  .dam-hero-title {
    display: inline-flex;
    align-items: baseline;
    gap: 0.32em;
    flex-wrap: nowrap;
    margin: 0;
    font-size: clamp(2.15rem, 3.5vw, 2.7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
    color: #4b6874;
    font-weight: 800;
    width: fit-content;
    max-width: none;
    white-space: nowrap;
  }

  .dam-hero-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex: 0 0 auto;
    padding-top: 4px;
  }

  .dam-hero-version {
    margin: 0;
    color: #5f90a2;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    white-space: nowrap;
  }

  .dam-hero-meta-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }

  .dam-hero-meta-pill {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.32);
    border: 1px solid rgba(121, 180, 201, 0.18);
    color: #5f90a2;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dam-hero-body {
    margin: 0;
    font-size: 1rem;
    line-height: 1.58;
    color: var(--text-main);
    max-width: 48ch;
  }

  .dam-hero-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .dam-hero-spec-pill {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.28);
    border: 1px solid rgba(121, 180, 201, 0.16);
    color: #5f90a2;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }

  .dam-hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .dam-hero-button {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 42px;
    padding: 0 18px;
    border-radius: 999px;
    background: linear-gradient(180deg, #648fa0, #5a8799);
    color: #fff;
    font-size: 0.84rem;
    font-weight: 700;
    box-shadow: 0 14px 28px rgba(95, 144, 162, 0.16);
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease, background 0.18s ease;
  }

  .dam-hero-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 15px 28px rgba(95, 144, 162, 0.2);
    background: linear-gradient(180deg, #5f8a9b, #557f90);
    filter: saturate(1.03);
  }

  @media (max-width: 720px) {
    .dam-hero-head {
      flex-direction: column;
      align-items: flex-start;
    }

    .dam-hero-meta {
      align-items: flex-start;
      padding-top: 0;
    }

    .dam-hero-meta-pills {
      justify-content: flex-start;
    }

    .dam-hero-body {
      max-width: none;
      font-size: 0.96rem;
    }

    .dam-hero-title {
      white-space: normal;
    }
  }
</style>
