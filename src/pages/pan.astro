---
const fallbackTarget = '/en/pan';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting...</title>
    <meta http-equiv="refresh" content={`0;url=${fallbackTarget}`} />
    <link rel="canonical" href={fallbackTarget} />
    <script is:inline define:vars={{ fallbackTarget }}>
      const savedLang = localStorage.getItem('preferred-language');
      const browserLang = navigator.language || navigator.userLanguage || '';
      const normalized = (savedLang || browserLang).toLowerCase();
      const target = normalized.startsWith('ja') || normalized.startsWith('jp')
        ? '/jp/pan'
        : '/en/pan';
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={fallbackTarget}>{fallbackTarget}</a>...</p>
  </body>
</html>
