---
import Layout from '../components/Layout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import SocialIconRow from '../components/SocialIconRow.astro';
import TabSwitcher from '../components/TabSwitcher.astro';
import LinkCard from '../components/LinkCard.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import TopazPanCard from '../components/TopazPanCard.astro';
import CommissionCard from '../components/CommissionCard.astro';
import PreviousWorksCarousel from '../components/PreviousWorksCarousel.astro';

import { languages, ui } from '../i18n/ui';
import { profileInfo, socialLinks, cardLinks, featuredData } from '../data/profile';
import { getPlaylistVideos } from '../utils/youtube';

// Evaluate initial language (default en) on the server for the first render
const defaultLang = 'en';
const t = (key: keyof typeof ui['en']) => ui[defaultLang][key];

const videos = await getPlaylistVideos('PLBRf9rHBrMc-4bXWqTUBIUfmRRw7Sjzy-');
const latestVideo = videos.length > 0 ? videos[0] : null;
const previousVideos = videos.length > 1 ? videos.slice(1) : [];

const featuredImage = latestVideo ? `https://img.youtube.com/vi/${latestVideo.id}/maxresdefault.jpg` : featuredData.imageUrl;
const featuredUrl = latestVideo ? `https://youtube.com/watch?v=${latestVideo.id}` : featuredData.videoUrl;

// Ensure we don't accidentally overwrite the user's manual "Latest cover" tag
const clientTranslations = JSON.parse(JSON.stringify(ui));
if (latestVideo && latestVideo.titles) {
  clientTranslations.en['video.title'] = latestVideo.titles.en;
  if (clientTranslations.ja) clientTranslations.ja['video.title'] = latestVideo.titles.ja;
}

// Map the previous videos to client translations
previousVideos.forEach(v => {
  clientTranslations.en[`video-${v.id}`] = v.titles.en;
  if (clientTranslations.ja) clientTranslations.ja[`video-${v.id}`] = v.titles.ja;
});

const featuredTitle = t('featured.badge');
const featuredI18nKey = 'featured.badge';
const videoTitle = latestVideo ? clientTranslations[defaultLang]['video.title'] : '';
---
<Layout title="とぱず / topaz">
  <!-- Pass translations to the client -->
  <script is:inline define:vars={{ translations: clientTranslations, defaultLang }}>
    window.translations = translations;
    
    // Auto-detect or restore language on load
    document.addEventListener("DOMContentLoaded", () => {
      let lang = localStorage.getItem('preferred-language');
      if (!lang) {
        const browserLang = navigator.language || navigator.userLanguage || '';
        const shortLang = browserLang.split('-')[0].toLowerCase();
        lang = translations[shortLang] ? shortLang : defaultLang;
      }
      
      // Initial set
      if (typeof window.setLanguage === 'function') {
        window.setLanguage(lang, false);
      }
    });

    window.setLanguage = function(lang, animate = true) {
      if (!translations[lang]) return;
      
      localStorage.setItem('preferred-language', lang);
      
      const targetEls = document.querySelectorAll('[data-i18n], .commission-card');
      
      if (animate) {
        targetEls.forEach(el => {
          el.style.transition = 'opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out';
          el.style.opacity = '0';
          el.style.transform = 'translateY(4px)';
          el.style.filter = 'blur(2px)';
        });
        
        setTimeout(() => {
          document.documentElement.lang = lang; // CSS based hiding happens here
          
          document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (translations[lang] && translations[lang][key]) {
              el.textContent = translations[lang][key];
            }
          });
          
          targetEls.forEach(el => {
            el.style.transition = 'none';
            el.style.transform = 'translateY(-4px)';
            void el.offsetWidth;
            el.style.transition = 'opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            el.style.filter = 'blur(0px)';
          });
        }, 150);
      } else {
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          if (translations[lang] && translations[lang][key]) {
            el.textContent = translations[lang][key];
          }
        });
      }
      
      // Update toggle buttons active state
      document.querySelectorAll('.lang-btn').forEach(btn => {
        if (btn.getAttribute('data-lang') === lang) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
    }
  </script>

  <style is:global>
    [data-i18n] {
      transition: opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out;
      display: inline-block; /* allows transforms to apply reliably */
    }
  </style>

  <ProfileHeader
    name={profileInfo.name}
    handle={profileInfo.handle}
    roleText={t('profile.role')}
    avatarUrl={profileInfo.avatarUrl}
  />
  <SocialIconRow links={socialLinks} t={t} />

  <TabSwitcher tab1={t('tab.main')} tab2={t('tab.special')} tab3={t('tab.commission')} />
  
  <div class="tabs-content">
    <div id="links-view" class="tab-view">
      <FeaturedCard
        imageUrl={featuredImage}
        altText={featuredData.altText}
        url={featuredUrl}
        badgeText={featuredTitle}
        badgeI18nKey={featuredI18nKey}
        videoTitle={videoTitle}
        videoTitleI18nKey="video.title"
      />
      <PreviousWorksCarousel 
        videos={previousVideos}
        titleI18nKey="previous.works"
        titleText={t('previous.works')}
        defaultLang={defaultLang}
      />
    </div>

    <div id="commission-view" class="tab-view" style="display: none; opacity: 0; transform: translateY(10px);">
      <CommissionCard />
    </div>

    <div id="projects-view" class="tab-view" style="display: none; opacity: 0; transform: translateY(10px);">
      <TopazPanCard 
        title={t('project.title')} 
        description={t('project.subtitle')} 
        githubText={t('project.github')} 
      />
    </div>
  </div>

</Layout>

<style>
  .tabs-content {
    position: relative;
    width: 100%;
  }

  .tab-view {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
</style>
